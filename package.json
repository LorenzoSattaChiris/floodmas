{
  "name": "floodmas-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && node --input-type=module -e \"import{cpSync}from'fs';cpSync('src/dataset','dist/dataset',{recursive:true});\"",
    "start": "node dist/index.js",
    "postinstall": "npm run build"
  },
  "dependencies": {
    "@atproto/api": "^0.19.4",
    "@tensorflow/tfjs": "^4.22.0",
    "adm-zip": "^0.5.16",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^8.0.0",
    "node-cache": "^5.1.2",
    "openai": "^6.32.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "proj4": "^2.20.4",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/pino-http": "^5.8.4",
    "@types/proj4": "^2.5.6",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
