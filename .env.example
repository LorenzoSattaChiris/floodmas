# FloodMAS Server — Environment Variables
#
# All external data sources are free public APIs — no API keys required.
# Copy this file to .env and adjust values as needed.

# HTTP port to listen on (default: 3000)
PORT=3000

# Set to 'production' to enable static SPA file serving from ../client/dist
NODE_ENV=development

# Met Office Weather DataHub API keys (optional — forecast layer won't load without these)
# Register at https://datahub.metoffice.gov.uk/
METOFFICE_SPOT_KEY=
METOFFICE_OBS_KEY=

# Copernicus Climate Data Store API key (optional — ERA5 reanalysis layer)
# Register at https://cds.climate.copernicus.eu/
CDS_API_KEY=

# Ordnance Survey Data Hub API key (optional — OS map tiles & place search)
# Register at https://osdatahub.os.uk/
OS_API_KEY=
